    "df.columns = [\"Name\", \"channel\", \"sigma\", \"Energie eV\"]\n",
    "df.dropna(inplace=True)\n",
    "\n",
    "y = df[\"Energie eV\"].astype(float)\n",
    "x = df[\"channel\"].astype(float)\n",
    "xerr = df[\"sigma\"].astype(float)\n",
    "df.head()"
   ]
