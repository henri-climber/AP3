   ],
   "source": [
    "# 4. Plotting\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "\n",
    "ax.errorbar(x, y, xerr=xerr, fmt='o', capsize=3, label=\"Messwerte\", markersize=4)\n",
    "ax.plot(x, m*x + c, color='red', \n",
    "        label=rf\"Fit: $m = ({m_u:.2u})$\" + \"\\n\" + rf\"$c = ({c_u:.2u})$\")\n",
    "\n",
    "ax.set_xlabel(\"Kanäle\")\n",
    "ax.set_ylabel(\"Energie / eV\")\n",
    "ax.legend()\n",
    "ax.grid(True, linestyle='--', alpha=0.6)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
