   ],
   "source": [
    "# 2. Linearer Fit mit Kovarianzmatrix\n",
    "coeffs, cov = np.polyfit(x, y, 1, cov=True)\n",
    "m, c = coeffs\n",
    "dm, dc = np.sqrt(np.diag(cov)) # Standardfehler (Wurzel der Varianz)\n",
    "\n",
    "m_u = ufloat(m, dm)\n",
    "c_u = ufloat(c, dc)\n",
    "\n",
    "# 3. Text-Ausgabe der Ergebnisse\n",
    "print(\"-\" * 30)\n",
    "print(f\"Fit-Ergebnisse:\")\n",
    "print(f\"Steigung m: {m_u:.2uP}\")\n",
    "print(f\"Achsenabschnitt c: {c_u:.2uP}\")\n",
    "print(\"-\" * 30)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "faa7f54d",
   "metadata": {},
   "outputs": [
    {
     "data": {
